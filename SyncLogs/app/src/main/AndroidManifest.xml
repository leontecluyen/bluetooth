<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Bluetooth (legacy permissions only up to API 30). -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- API 31+: connect to bonded device; scan needed only if discovering. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />

    <!-- Location: geofencing requires fine location; background needed for ENTER
         events while the app is not in the foreground (API 29+). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Post the "tap to enable Bluetooth" notification from the geofence trigger (API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SyncLogsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SyncLogs">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="@string/app_name"
            android:theme="@style/Theme.SyncLogs">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Màn hình gửi log (mở từ nút menu ở MainActivity). -->
        <activity
            android:name=".LogSendActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:label="@string/logsend_title"
            android:theme="@style/Theme.SyncLogs" />

        <!-- Receives GEOFENCE_TRANSITION_ENTER from Play Services. -->
        <receiver
            android:name=".geofence.GeofenceBroadcastReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="leontec.jp.synclogs.action.GEOFENCE_EVENT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
