{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8090"
      }
    }
  },

  "Sync": {
    "BluetoothServiceName": "SyncLogServer"
  },

  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=synclogs.db"

    // --- SQL Server example ---
    // "Provider": "SqlServer",
    // "ConnectionString": "Server=localhost;Database=LeontecSync;Trusted_Connection=True;TrustServerCertificate=True"

    // --- PostgreSQL example ---
    // "Provider": "Postgres",
    // "ConnectionString": "Host=localhost;Database=leontec_sync;Username=postgres;Password=postgres"
  }
}
