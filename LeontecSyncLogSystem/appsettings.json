{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8090"
      }
    }
  },

  "Sync": {
    "BluetoothServiceName": "SyncLogServer",
    // Empty ⇒ <root>/_backup (sibling of the app folder). Set an absolute path to override,
    // e.g. "C:\\LeontecBackup". Each received CSV is saved to <BackupFolder>/<yyyyMMdd>/<filename>.
    "BackupFolder": ""
  }

  // Database: the app connects to an EXTERNAL MySQL that is installed/run separately. Its connection
  // settings live in <root>/mysql.xml (host/port/database/user/password), NOT here — see MySqlConfig.
}
