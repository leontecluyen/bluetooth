{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8090"
      }
    }
  },

  "Sync": {
    "BluetoothServiceName": "SyncLogServer",
    // Empty ⇒ %LOCALAPPDATA%/LeontecSyncLogSystem/backup. Set an absolute path to override,
    // e.g. "C:\\LeontecBackup". Each received CSV is saved to <BackupFolder>/<yyyyMMdd>/<filename>.
    "BackupFolder": ""
  },

  // Database = bundled MariaDB (Pomelo). Embedded=true runs the app's own MariaDB under
  // <app>/mariadb/ on a private port — no separate install needed. Set Embedded=false to use an
  // external MySQL/MariaDB via ConnectionString.
  "Database": {
    "Embedded": true,
    "EmbeddedPort": 3307,
    "DataDir": "",
    "ConnectionString": "Server=localhost;Port=3306;Database=leontec_sync;User=root;Password=;"
  }
}
